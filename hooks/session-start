#!/usr/bin/env bash
# SessionStart hook for the testctl plugin — quiet awareness, never auto-runs.
set -euo pipefail

MSG="testctl is installed: /testctl:test-all (discover + run tests across the project), /testctl:generate-tests (write missing smoke + unit tests across Frappe, Flutter, Electron, Next.js, Supabase, and Web (React/Vue)), /testctl:fix-failures (root-cause + fix red tests), /testctl:production-ready (drive a project to green: discover, generate, run, fix, report), /testctl:harden (add edge-case tests to happy-path-only suites), /testctl:coverage-boost (write tests for the specific uncovered lines), /testctl:test-audit (review tests for quality — find green-but-worthless suites), /testctl:mutation-testing (prove tests catch bugs — surgically break code, find tests that don't fail, then write killing tests), /testctl:regression-from-bug (turn a bug/stack-trace into a failing reproduction test), /testctl:flaky-hunter (find + stabilize flaky tests), /testctl:data-factory (generate reusable test-data builders), /testctl:tax-guard (test VAT/GST/sales-tax correctness on invoices, from the project's own tax config — any country), /testctl:permissions-guard (test access control — deny unauthorized, enforce roles, isolate records), /testctl:money-guard (test money math — rounding, no float drift, totals reconcile, multi-currency), /testctl:date-tz-guard (test date/time — no tz off-by-one, DST, boundaries, duration math), /testctl:api-contract (test API contracts — status, response shape, error envelope, auth, pagination), /testctl:migration-guard (protect Frappe data patches — idempotency, no data loss, intended transform, by calling execute() directly in a FrappeTestCase), /testctl:perf-guard (catch performance regressions — deterministic no-N+1: expensive-call count must not grow with input size, never wall-clock), /testctl:i18n-guard (test internationalization — translation completeness / key parity, RTL directionality, locale-aware display, from the project's own configured locales; never hardcodes a language), /testctl:test-this (write a test from a plain-English behaviour), /testctl:e2e (generate anti-flaky end-to-end / user-journey tests — Playwright for Next/React/Vue + Electron, integration_test for Flutter; never runs against production), /testctl:snapshot (golden/snapshot tests for output-heavy code), /testctl:scaffold (zero-to-one test harness for an app with none), /testctl:mock-externals (stub email/SMS/payment/webhooks/HTTP so tests never hit real services — vital on restored prod data), /testctl:security-guard (defensive security tests for your own app — injection/XSS/access-control/secrets/SSRF/deserialization/DoS-resilience). /testctl:frappe-bootstrap (unblock Frappe test bootstrap — generate a test-only before_tests hook that seeds mandatory fields on _Test Company etc.). /testctl:preflight (check a Frappe bench's test-readiness — dev reqs, allow_tests, encryption key, before_tests — before running). When the user is working on testing, asks whether a project is production-ready, or wants tests run/written/fixed, OFFER the relevant command. Do not run anything automatically and do not repeat this notice."

# Escape for JSON embedding (backslash, quote, control chars).
escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

CTX="$(escape_for_json "$MSG")"

# Claude Code expects hookSpecificOutput.additionalContext; others take top-level additionalContext.
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$CTX"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$CTX"
fi
exit 0
