#!/usr/bin/env bash
# SessionStart hook for the testctl plugin — quiet awareness, never auto-runs.
set -euo pipefail

MSG="testctl is installed: /testctl:test-all (discover + run tests across the project), /testctl:generate-tests (write missing smoke + unit tests), /testctl:fix-failures (root-cause + fix red tests), /testctl:production-ready (drive a project to green: discover, generate, run, fix, report), /testctl:harden (add edge-case tests to happy-path-only suites), /testctl:coverage-boost (write tests for the specific uncovered lines), /testctl:test-audit (review tests for quality — find green-but-worthless suites), /testctl:regression-from-bug (turn a bug/stack-trace into a failing reproduction test), /testctl:flaky-hunter (find + stabilize flaky tests), /testctl:data-factory (generate reusable test-data builders), /testctl:tax-guard (test VAT/GST/sales-tax correctness on invoices, from the project's own tax config — any country), /testctl:permissions-guard (test access control — deny unauthorized, enforce roles, isolate records), /testctl:money-guard (test money math — rounding, no float drift, totals reconcile, multi-currency), /testctl:date-tz-guard (test date/time — no tz off-by-one, DST, boundaries, duration math), /testctl:api-contract (test API contracts — status, response shape, error envelope, auth, pagination), /testctl:test-this (write a test from a plain-English behaviour), /testctl:snapshot (golden/snapshot tests for output-heavy code), /testctl:scaffold (zero-to-one test harness for an app with none). When the user is working on testing, asks whether a project is production-ready, or wants tests run/written/fixed, OFFER the relevant command. Do not run anything automatically and do not repeat this notice."

# Escape for JSON embedding (backslash, quote, control chars).
escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

CTX="$(escape_for_json "$MSG")"

# Claude Code expects hookSpecificOutput.additionalContext; others take top-level additionalContext.
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$CTX"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$CTX"
fi
exit 0
